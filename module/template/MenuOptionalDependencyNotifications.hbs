<form class="ve-flex-col ve-window ve-min-h-0 ve-h-100 ve-relative">
	<h4>Hide Notifications for Optional Dependencies:</h4>

	{{#each modules as |module ix|}}
		<label class="ve-flex-v-center ve-py-1 ve-w-100">
			<div class="ve-flex-col ve-w-100 ve-mr-2">
				<div class="ve-flex-v-center ve-mb-1">
					<span class="ve-bold ve-mr-1">{{title}}</span>
					<span class="ve-muted ve-small">({{id}})</span>
				</div>

				<div class="ve-small"><a href="https://foundryvtt.com/packages/{{id}}" rel="noopener noreferrer">https://foundryvtt.com/packages/{{id}}</a></div>
			</div>

			<div class="ve-flex">
				<input type="checkbox" data-dtype="Boolean" class="ve-m-0" name="{{id}}" {{checked isChecked}}>
			</div>
		</label>
	{{/each}}

	<button type="submit" class="ve-mt-1"><i class="fas fa-save"></i> Save Changes</button>
</form>
